# ─── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (create the database first, then run npm start)
DATABASE_URL=postgresql://user:password@localhost:5432/guadalupe_sentinel

# Random secret for Express session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=replace_with_a_long_random_string


# ─── Optional: AI briefings ────────────────────────────────────────────────────

# OpenAI key for basin/gauge AI summaries (app works without it — briefings disabled)
OPENAI_API_KEY=sk-...


# ─── Optional: Admin panel (required for encrypted GUI config) ─────────────────

# 64-character hex key used to AES-256-GCM encrypt secrets stored in Postgres.
# Generate with: openssl rand -hex 32
# This is the ONLY secret that must live in env — everything else can be set via /admin.
CONFIG_ENCRYPTION_KEY=replace_with_64_hex_chars

# Email address to auto-promote to admin on first login/register.
INITIAL_ADMIN_EMAIL=you@example.com


# ─── Optional: Stripe billing ──────────────────────────────────────────────────
# These can be set here OR via the admin panel at /admin (recommended).

# Stripe secret key (from dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...

# Price IDs (create in Stripe dashboard → Products → Add product)
STRIPE_PRICE_ID_PRO=price_...          # monthly plan
STRIPE_PRICE_ID_PRO_ANNUAL=price_...   # annual plan (optional)

# Webhook signing secret (Stripe dashboard → Webhooks → add endpoint)
# Endpoint URL: https://your-domain.com/api/billing/webhook
# Events: customer.subscription.* and invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...


# ─── Optional: Twilio SMS ──────────────────────────────────────────────────────
# Can also be set via the admin panel at /admin.

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15551234567


# ─── Optional: Replit OIDC auth ────────────────────────────────────────────────
# Only needed when deploying on Replit. Leave blank on other platforms.

REPL_ID=
REPLIT_DOMAINS=your-app.replit.app,your-app.repl.co
REPLIT_DEV_DOMAIN=
ISSUER_URL=https://replit.com/oidc


# ─── Optional: Push notifications & email ──────────────────────────────────────

# VAPID subject for Web Push (must be a mailto: or https: URI)
VAPID_SUBJECT=mailto:ops@your-domain.com

# Public base URL used in notification links and Stripe redirects
PUBLIC_URL=https://your-domain.com

# Replit Mail connector (Replit deployments only)
REPLIT_CONNECTORS_HOSTNAME=


# ─── Server ────────────────────────────────────────────────────────────────────

# Port the API server listens on (default: 3001)
PORT=3001

# Set to 'production' to enable secure cookies and production optimisations
NODE_ENV=development
