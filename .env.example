# ── Database ─────────────────────────────────────────────────────────────────
# Railway sets this automatically when you add a PostgreSQL plugin.
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Sessions ─────────────────────────────────────────────────────────────────
# Any long random string — generate one with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── Google OAuth ─────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI: https://YOUR_DOMAIN/api/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of domains the app is reachable at (scopes OAuth callbacks)
ALLOWED_DOMAINS=yourdomain.railway.app

# ── Public URL ───────────────────────────────────────────────────────────────
# Base URL for links in outbound alert emails. Set to your Railway-generated URL.
PUBLIC_URL=https://yourdomain.railway.app

# ── Server port ──────────────────────────────────────────────────────────────
# Railway injects PORT automatically — only set this when running locally.
# PORT=3001

# ── OpenAI (optional) ────────────────────────────────────────────────────────
# Required only for AI river briefing feature. Pro plan users only.
OPENAI_API_KEY=

# ── SMTP email (optional) ────────────────────────────────────────────────────
# Required only if you want the email alert delivery channel.
# Works with SendGrid, Mailgun, AWS SES, Postmark, or any SMTP provider.
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=SG.xxx
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@yourdomain.com

# -- Supabase (for Google OAuth / auth) ---------------------------
# Get these from: https://supabase.com/dashboard -> your project -> Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# To activate Google sign-in, paste your Google OAuth credentials in the
# Supabase dashboard: Authentication -> Providers -> Google
